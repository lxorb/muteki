# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/

# Coverage
.coverage
.coverage.*
htmlcov/

# IDE / editor files
.vscode/*
!.vscode/settings.example.json
.idea/*
!.idea/.gitignore
!.idea/watcherTasks.xml

# OS files
.DS_Store
Thumbs.db

# cbc
*.replay*
/profiles/
replay_*.json

# local test bot
/src/bots/test_bot.py
/bots/test_bot/

# excluded constants
/bots/exclude/exclude.py

# unrated runner

# queued match ids (may not be current anymore)
/tools/unrated_runner/data/queued.json
# partial results (only useful in the case of conflicts)
/tools/unrated_runner/results/partial/
# output logs (can generate at any time)
/tools/unrated_runner/outputs/