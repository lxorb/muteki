# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/

# Coverage
.coverage
.coverage.*
htmlcov/

# IDE / editor files
.vscode/*
!.vscode/settings.example.json
.idea/*
!.idea/.gitignore
!.idea/watcherTasks.xml

# OS files
.DS_Store
Thumbs.db

# cbc
*.replay*
/profiles/
replay_*.json
/tools/replay_parser/last_replay.parsed.json

# local test bot
/src/bots/test_bot.py
/bots/test_bot/

# excluded constants
/bots/exclude/exclude.py

# unrated runner

# discord webhook secret
/tools/unrated_runner/config/discord_webhook.txt
# data (auto-generated)
/tools/unrated_runner/data/
# graphs (can generate at any time)
/tools/unrated_runner/graphs
# partial results (only useful in the case of conflicts)
/tools/unrated_runner/results/
# output logs (can generate at any time)
/tools/unrated_runner/outputs/
# compare logs (can generate at any time)
/tools/unrated_runner/compares/
